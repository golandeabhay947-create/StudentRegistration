<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

    <!-- Sidebar -->
    <aside class="sidebar">
        <h2>MyPanel</h2>
        <ul>
            <li>🏠 Dashboard</li>
            <li>👨‍🎓 Students</li>
            <li>📚 Courses</li>
            <li>📝 Exams</li>
            <li>📊 Results</li>
            <li>⚙ Settings</li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main">

        <header>
            <h1>Admin Dashboard</h1>
        </header>

        <!-- Cards -->
        <section class="cards">
            <div class="card">
                <h3>Students</h3>
                <p>1500</p>
            </div>

            <div class="card">
                <h3>Courses</h3>
                <p>40</p>
            </div>

            <div class="card">
                <h3>Exams</h3>
                <p>25</p>
            </div>

            <div class="card">
                <h3>Revenue</h3>
                <p>₹80,000</p>
            </div>
        </section>

        <!-- Table -->
        <section class="table-section">
            <h2>Recent Activity</h2>

            <table>
                <tr>
                    <th>Name</th>
                    <th>Course</th>
                    <th>Status</th>
                </tr>
                <tr>
                    <td>Rahul</td>
                    <td>Java</td>
                    <td>Completed</td>
                </tr>
                <tr>
                    <td>Sneha</td>
                    <td>Python</td>
                    <td>Ongoing</td>
                </tr>
                <tr>
                    <td>Amit</td>
                    <td>Web Dev</td>
                    <td>Completed</td>
                </tr>
            </table>
        </section>

    </main>

</div>

</body>
</html>